#!/bin/sh

set -e  # Exit on error

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_message() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

echo ""

{{ if eq .chezmoi.os "linux" }}
    
    if command -v mise >/dev/null 2>&1; then
        print_message "Installing Mise Packages..."
        
        mise use -g rust
        mise use -g rust-analyzer

        mise use -g clang
        mise use -g clang-format

        mise use -g lua
        mise use -g lua-language-server
        mise use -g stylua
    fi

{{ end }}
