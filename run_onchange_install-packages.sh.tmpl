#            sudo dnf copr enable wezfurlong/wezterm-nightly -y
#        else
#            print_message "wezterm-nightly COPR already enabled, skipping..."
#        fi

        sudo dnf install -y \
            git \
            git-crypt \
            delta \
            gnupg \
            stow \
	    nvim \
            zsh \
            zoxide \
            fzf \
            fastfetch \
            onefetch \
            cargo \
            nix \
            jetbrains-mono-nl-fonts.noarch \
            xz \
